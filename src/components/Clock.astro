---
interface Props {
  label?: string;
  class?: string;
}
const { label = 'Liverpool, UK', class: className } = Astro.props;
---

<span class:list={['inline-flex items-center gap-2', className]}>
  <span class="live-dot" aria-hidden="true"></span>
  <span>{label}</span>
  <time data-clock>--:--:--</time>
</span>

<script>
  const fmt = new Intl.DateTimeFormat('en-GB', {
    timeZone: 'Europe/London',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false,
  });
  const nodes = document.querySelectorAll('[data-clock]');
  const tick = () => {
    const now = fmt.format(new Date());
    nodes.forEach((n) => (n.textContent = now));
  };
  tick();
  setInterval(tick, 1000);
</script>
