---
import { projects } from '../data/projects';
import PwDemo from './PwDemo.astro';
---

<section id="work" class="px-5 pb-28 md:px-10 md:pb-44">
  <h2 class="mb-6 font-mono text-xs tracking-[0.18em] text-muted uppercase">
    <span class="text-accent">(02)</span> Selected Work
  </h2>

  <ul class="border-t border-white/10">
    {
      projects.map((p) => (
        <li class="border-b border-white/10" data-fade>
          <div class="py-8 md:py-10">
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-3 md:gap-x-8">
              <span class="font-mono text-sm text-accent">({p.n})</span>
              {p.links.length > 0 ? (
                <a href={p.links[0].href} target="_blank" rel="noopener" class="group" data-cursor="View ↗">
                  <span class="font-display block text-[1.65rem] leading-none font-bold tracking-tight uppercase transition-[color,translate] duration-300 group-hover:translate-x-2 group-hover:text-accent md:text-6xl">
                    {p.title}
                  </span>
                </a>
              ) : (
                <span class="font-display text-[1.65rem] leading-none font-bold tracking-tight uppercase md:text-6xl">
                  {p.title}
                </span>
              )}
              <span class="ml-auto flex gap-5 font-mono text-[11px] tracking-[0.14em] uppercase md:text-xs">
                {p.links.map((l) => (
                  <a class="link-hover" href={l.href} target="_blank" rel="noopener">
                    {l.label}&nbsp;↗
                  </a>
                ))}
                {p.note && <span class="text-muted">({p.note})</span>}
              </span>
            </div>

            <div class="mt-5 max-w-3xl md:pl-[4.5rem]">
              <p class="mb-3 font-mono text-xs tracking-[0.14em] text-muted uppercase">{p.sub}</p>
              <p class="mb-5 leading-relaxed text-muted">{p.desc}</p>
              <ul class="flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <li class="rounded-full border border-white/15 px-3.5 py-1.5 font-mono text-xs text-ink/80">{t}</li>
                ))}
              </ul>
              {p.demo && <PwDemo />}
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</section>
