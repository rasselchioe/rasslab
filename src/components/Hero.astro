---
import Clock from './Clock.astro';
import Marquee from './Marquee.astro';

const marqueeItems = [
  'Cybersecurity',
  'Software Testing',
  'Full-Stack Development',
  'TypeScript',
  'React',
  'Node.js',
  'Python',
  'SQL',
  'Playwright',
  'Linux',
  'Photography',
  'Road Cycling',
  'Travel',
];
---

<section id="top" class="relative flex min-h-svh flex-col overflow-hidden">
  <canvas id="plusgrid" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

  <div class="relative flex flex-1 flex-col justify-center px-5 pt-24 md:px-10">
    <p data-hero-fade class="mb-5 flex items-center gap-3 font-mono text-sm text-accent md:text-base">
      <span class="inline-block h-px w-9 bg-accent" aria-hidden="true"></span>
      <span class="inline-flex overflow-hidden">
        <span data-greeting class="inline-block">Hello</span>
      </span>
      <span class="caret -ml-2" aria-hidden="true">_</span>
    </p>

    <h1 class="font-display text-[clamp(3.8rem,15vw,14.5rem)] leading-[0.9] font-bold tracking-[-0.03em] uppercase">
      <span class="block overflow-hidden"><span class="hero-line block">Rassel</span></span>
      <span class="block overflow-hidden"><span class="hero-line text-outline block">Chioe</span></span>
    </h1>

    <p data-hero-fade class="mt-8 max-w-xl text-base leading-relaxed text-pretty text-muted md:text-lg">
      Computer Science student
      <span class="text-ink">(BSc with Year in Industry, cybersecurity focus)</span>
      at the University of Liverpool — seeking a
      <span class="text-ink">2026/27 placement year</span>
      in cybersecurity, software testing, or IT.
    </p>
  </div>

  <div
    class="relative flex items-end justify-between gap-6 px-5 pb-5 font-mono text-[11px] tracking-[0.14em] text-muted uppercase md:px-10 md:text-xs"
  >
    <p data-hero-fade><Clock label="Liverpool, UK" /></p>
    <p data-hero-fade class="scroll-hint hidden sm:block">(Scroll to learn more)</p>
    <ul data-hero-fade class="flex gap-5">
      <li>
        <a class="link-hover" href="https://github.com/rasselchioe" target="_blank" rel="noopener">GitHub&nbsp;↗</a>
      </li>
      <li>
        <a class="link-hover" href="https://linkedin.com/in/rassel-susanto-chioe" target="_blank" rel="noopener">
          LinkedIn&nbsp;↗
        </a>
      </li>
    </ul>
  </div>

  <div data-hero-fade class="relative border-t border-white/10">
    <Marquee
      items={marqueeItems}
      class="py-3.5 font-mono text-xs tracking-[0.18em] text-muted uppercase"
    />
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { initPlusGrid } from '../scripts/plusgrid';

  const canvas = document.querySelector<HTMLCanvasElement>('#plusgrid');
  if (canvas) initPlusGrid(canvas);

  // Rotating greeting — Hello / Bonjour / Hola / Olá / 你好
  const word = document.querySelector<HTMLElement>('[data-greeting]');
  if (word && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const words = ['Hello', 'Bonjour', 'Hola', 'Olá', '你好'];
    let i = 0;
    const cycle = () => {
      gsap.to(word, {
        yPercent: -120,
        duration: 0.38,
        ease: 'power3.in',
        delay: 2.2,
        onComplete: () => {
          i = (i + 1) % words.length;
          word.textContent = words[i] ?? 'Hello';
          gsap.fromTo(
            word,
            { yPercent: 120 },
            { yPercent: 0, duration: 0.38, ease: 'power3.out', onComplete: cycle },
          );
        },
      });
    };
    cycle();
  }
</script>
