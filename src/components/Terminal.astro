<div id="terminal" class="fixed inset-0 z-[950] hidden" role="dialog" aria-modal="true" aria-label="rasslab terminal">
  <div id="term-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div id="term-panel" class="absolute inset-x-0 bottom-0 border-t border-white/15 bg-[#050505] px-5 pt-4 pb-6 md:px-10">
    <div class="mb-4 flex items-baseline justify-between gap-4 font-mono text-[11px] tracking-[0.14em] text-muted uppercase">
      <p><span class="text-accent">guest@rasslab.dev</span> — interactive shell</p>
      <p>[esc] close</p>
    </div>
    <div
      id="term-out"
      data-lenis-prevent
      class="max-h-[38svh] overflow-y-auto font-mono text-[13px] leading-6 whitespace-pre-wrap md:text-sm md:leading-7"
      aria-live="polite"
    >
    </div>
    <form id="term-form" class="mt-1 flex items-center gap-3 font-mono text-[13px] md:text-sm">
      <span class="text-accent" aria-hidden="true">$</span>
      <input
        id="term-input"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="send"
        placeholder="type 'help'"
        aria-label="Terminal command"
        class="min-w-0 flex-1 bg-transparent text-ink outline-none placeholder:text-muted/60"
      />
    </form>
  </div>
</div>

<script>
  import { initTerminal } from '../scripts/terminal';
  initTerminal();
</script>
