---
interface Props {
  items: string[];
  class?: string;
}
const { items, class: className } = Astro.props;
---

<!-- Loop speed lives in .marquee-track (CSP forbids inline styles). -->
<div class:list={['marquee', className]} aria-hidden="true">
  <div class="marquee-track">
    {
      [0, 1].map(() => (
        <span class="marquee-seg">
          {items.map((item) => (
            <span class="inline-flex items-center">
              {item}
              <span class="mx-5 text-accent">+</span>
            </span>
          ))}
        </span>
      ))
    }
  </div>
</div>
