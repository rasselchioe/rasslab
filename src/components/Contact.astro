---
import Clock from './Clock.astro';

const links = [
  { label: 'rasselchioe@gmail.com', href: 'mailto:rasselchioe@gmail.com' },
  { label: 'GitHub', href: 'https://github.com/rasselchioe', external: true },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/rassel-susanto-chioe', external: true },
  { label: 'CV (PDF)', href: '/cv.pdf', external: true },
];
---

<section id="contact" class="relative overflow-hidden px-5 pt-28 pb-6 md:px-10 md:pt-44">
  <h2 class="mb-6 font-mono text-xs tracking-[0.18em] text-muted uppercase">
    <span class="text-accent">(04)</span> Contact
  </h2>

  <p data-reveal class="font-display max-w-3xl text-2xl leading-[1.15] font-medium tracking-tight text-balance md:text-4xl">
    Seeking a <span class="text-accent">2026/27 placement year</span> in cybersecurity, software testing or IT —
    based in Liverpool, open to Manchester.
  </p>

  <a href="mailto:rasselchioe@gmail.com" class="group mt-12 block md:mt-16" data-fade>
    <span class="font-display block text-[clamp(3.2rem,12vw,11rem)] leading-[0.95] font-bold tracking-[-0.03em] uppercase">
      <span class="block transition-colors duration-300 group-hover:text-accent">Get in</span>
      <span class="text-outline block transition-colors duration-300 group-hover:text-accent">touch&nbsp;↗</span>
    </span>
  </a>

  <ul data-fade class="mt-12 flex flex-wrap gap-x-8 gap-y-3 font-mono text-[11px] tracking-[0.14em] uppercase md:mt-16 md:text-xs">
    {
      links.map((l) => (
        <li>
          <a
            class="link-hover"
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener' : undefined}
          >
            {l.label}&nbsp;↗
          </a>
        </li>
      ))
    }
  </ul>

  <footer
    class="mt-20 flex flex-wrap items-center justify-between gap-4 border-t border-white/10 pt-5 pb-2 font-mono text-[11px] tracking-[0.14em] text-muted uppercase md:mt-28 md:text-xs"
  >
    <p>&copy; 2026 Rassel Chioe</p>
    <p class="hidden sm:block">(design — test — secure — repeat)</p>
    <p><Clock label="Liverpool, UK" /></p>
  </footer>
</section>
