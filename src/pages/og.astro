---
// 1200×630 source for public/og.png — regenerate with:
//   npm run dev
//   node <scratchpad>/shot-og.mjs  (Playwright screenshot of /og at 1200×630)
import '../styles/global.css';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>OG card source — rasslab.dev</title>
  </head>
  <body class="bg-bg font-body text-ink">
    <main class="relative flex h-[630px] w-[1200px] flex-col justify-between overflow-hidden p-16">
      <span
        aria-hidden="true"
        class="text-outline-faint font-display absolute -top-14 right-8 text-[18rem] leading-none font-bold select-none"
      >
        +
      </span>
      <span
        aria-hidden="true"
        class="text-outline-faint font-display absolute right-72 bottom-20 text-[8rem] leading-none font-bold select-none"
      >
        +
      </span>

      <div class="flex items-baseline justify-between font-mono text-2xl">
        <span class="font-bold tracking-tight">RL<span class="text-accent">/</span></span>
        <span class="text-muted">rasslab.dev</span>
      </div>

      <h1 class="font-display text-[9.5rem] leading-[0.9] font-bold tracking-[-0.03em] uppercase">
        <span class="block">Rassel</span>
        <span class="text-outline block">Chioe</span>
      </h1>

      <div class="flex items-end justify-between font-mono text-[21px] tracking-[0.12em] uppercase">
        <p><span class="text-accent">Cybersecurity</span> <span class="text-muted">· Software Testing · Full-Stack</span></p>
        <p class="text-muted">Liverpool, UK</p>
      </div>
    </main>
  </body>
</html>
